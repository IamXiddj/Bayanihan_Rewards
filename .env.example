# Bayanihan Rewards — testnet environment
#
# Everything below is a public address or contract ID — none of it is
# secret. The Supabase keys are left blank since that project doesn't exist
# yet. Once filled in, keep this file out of version control (it should
# already be covered by Next.js's default .gitignore, but worth double
# checking — `git check-ignore .env.local` should print the filename).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Rotate this before relying on it further — it was pasted into chat, see the
# note above. Swap in the new value once you've regenerated it in the
# Supabase dashboard.
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_STELLAR_NETWORK=
NEXT_PUBLIC_FREIGHTER_NETWORK=

# Both prefixed and unprefixed versions are kept: contract.Client has to run
# in the browser too (Freighter can only sign there), so it needs the
# NEXT_PUBLIC_ versions; SOROBAN_RPC_URL/SOROBAN_CONTRACT_ID are kept
# unprefixed too in case a server-only route wants to reference them without
# depending on the client bundle's env inlining.
SOROBAN_RPC_URL=
SOROBAN_CONTRACT_ID=
NEXT_PUBLIC_SOROBAN_RPC_URL=
NEXT_PUBLIC_SOROBAN_CONTRACT_ID=

# The BAYANI Stellar Asset Contract (SAC) — not in the original spec's env
# template, but the frontend needs it directly to check balances / build
# trustline prompts independently of the rewards contract above.
BAYANI_TOKEN_CONTRACT_ID=
NEXT_PUBLIC_BAYANI_TOKEN_CONTRACT_ID=
BAYANI_ISSUER_ADDRESS=
NEXT_PUBLIC_BAYANI_ISSUER_ADDRESS=
